# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=AgriMemo
APP_VERSION=1.0.0
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MAX_AUDIO_FILE_SIZE_MB=25
AUDIO_TEMP_DIR=/tmp/agrimemo_audio

# ── Deepgram ──────────────────────────────────────────────────────────────────
# Get your API key from https://console.deepgram.com/
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY_HERE
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_PUNCTUATE=true
STT_MAX_RETRIES=3
STT_RETRY_BASE_SECONDS=2
STT_TIMEOUT_SECONDS=60
STT_CONFIDENCE_THRESHOLD=0.75

# ── Cloudflare Workers AI ──────────────────────────────────────────────────────
# Get your API token from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN_HERE
# Your Account ID is visible in the Cloudflare Dashboard URL
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID_HERE
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# AI Gateway (optional — leave empty to call Workers AI directly)
CLOUDFLARE_AI_GATEWAY_NAME=agrimemo-gateway
# When set, calls go through:
# https://gateway.ai.cloudflare.com/v1/{ACCOUNT_ID}/{GATEWAY_NAME}/workers-ai/{MODEL}

CF_AI_MAX_RETRIES=2
CF_AI_TIMEOUT_SECONDS=30
CF_AI_MAX_TOKENS=1024
CF_AI_TEMPERATURE=0.1

# ── Storage ───────────────────────────────────────────────────────────────────
JSON_STORE_PATH=./data/notes.json
EVENT_LOG_PATH=./data/events.jsonl

# ── Deduplication ─────────────────────────────────────────────────────────────
DEDUP_ENABLED=true
DEDUP_SIMILARITY_THRESHOLD=0.88
DEDUP_WINDOW_MINUTES=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=150
